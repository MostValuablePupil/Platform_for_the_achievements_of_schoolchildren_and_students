# === ОСНОВНЫЕ НАСТРОЙКИ ===
# Выключить режим отладки для продакшена!
DEBUG=0

# Секретный ключ Django (ОБЯЗАТЕЛЬНО СМЕНИТЕ)
# Можно сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_production_secret_key_here

# Домены вашего сервера (через запятую, без пробелов, без http://)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com
# Доверенные источники для CSRF (с http:// или https://)
DJANGO_CSRF_TRUSTED_ORIGINS=http://yourdomain.com,https://yourdomain.com
# Разрешенные CORS (с http:// или https://)
CORS_ALLOWED_ORIGINS=http://yourdomain.com,https://yourdomain.com
# Отключить разрешение всех источников для продакшена
CORS_ALLOW_ALL_ORIGINS=0

# === БАЗА ДАННЫХ ===
DB_NAME=mvp_prod
DB_USER=mvp_user
# Придумайте сложный пароль
DB_PASSWORD=your_secure_db_password

# === НАСТРОЙКИ ИНТЕГРАЦИЙ ===
# API-ключ для GigaChat (LLM для анализа достижений)
API_KEY=YOUR_GIGACHAT_API_KEY_HERE

# Токен Telegram-бота
TELEGRAM_BOT_API_KEY=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Секретный код для регистрации куратора
CURATOR_REGISTRATION_CODE=super_secret_curator_code

# === НАСТРОЙКИ EMAIL ===
# Для продакшена используйте реальный SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Пример для Яндекса:
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your_email@yandex.ru
EMAIL_HOST_PASSWORD=your_app_password

# Адрес отправителя
DEFAULT_FROM_EMAIL=your_email@yandex.ru

# Базовый URL фронтенда (используется для формирования ссылок в письмах)
FRONTEND_URL=https://yourdomain.com
