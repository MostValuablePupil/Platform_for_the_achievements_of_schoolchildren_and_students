# === ОСНОВНЫЕ НАСТРОЙКИ ===
# Выключить режим отладки для продакшена!
DEBUG=0

# Секретный ключ Django. Генерируется один раз, не менять в продакшне.
# Можно сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_production_secret_key_here

# Домены вашего сервера (через запятую, без пробелов, без http://)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com
# Доверенные источники для CSRF (с http:// или https://)
DJANGO_CSRF_TRUSTED_ORIGINS=http://yourdomain.com,https://yourdomain.com
# Разрешенные CORS (с http:// или https://)
CORS_ALLOWED_ORIGINS=http://yourdomain.com,https://yourdomain.com
# Отключить разрешение всех источников для продакшена
CORS_ALLOW_ALL_ORIGINS=0

# === БАЗА ДАННЫХ ===
# В docker-compose DB_HOST и DB_PORT задаются автоматически.
POSTGRES_DB=mvp_prod
POSTGRES_USER=mvp_user
POSTGRES_PASSWORD=your_secure_db_password

# === НАСТРОЙКИ ИНТЕГРАЦИЙ ===
# API-ключ для GigaChat (LLM для анализа достижений)
API_KEY=YOUR_GIGACHAT_API_KEY_HERE

# Токен Telegram-бота
TELEGRAM_BOT_API_KEY=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Секретный код для регистрации куратора.
# Сообщи его только тем, кто должен регистрироваться куратором.
CURATOR_REGISTRATION_CODE=super_secret_curator_code

# === НАСТРОЙКИ EMAIL ===
# Бэкенд отправки писем.
# Для разработки: django.core.mail.backends.console.EmailBackend (письма печатаются в терминал)
# Для продакшна: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Настройки SMTP-сервера. Выбери один из вариантов:
#
# Яндекс (рекомендуется — работает с обычным паролем):
#   EMAIL_HOST=smtp.yandex.ru
#   EMAIL_PORT=465
#   EMAIL_USE_TLS=False
#   EMAIL_USE_SSL=True
#
# Gmail (требует пароль приложения: https://myaccount.google.com/apppasswords):
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_USE_SSL=False
#
# Mail.ru:
#   EMAIL_HOST=smtp.mail.ru
#   EMAIL_PORT=465
#   EMAIL_USE_TLS=False
#   EMAIL_USE_SSL=True

# Ниже раскомментирован пример для Яндекса:
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True

# Логин и пароль от почтового ящика-отправителя
EMAIL_HOST_USER=your_email@yandex.ru
EMAIL_HOST_PASSWORD=your_app_password

# Адрес отправителя, который увидит получатель
DEFAULT_FROM_EMAIL=your_email@yandex.ru

# Базовый URL фронтенда — используется для формирования ссылок подтверждения email
FRONTEND_URL=https://yourdomain.com
